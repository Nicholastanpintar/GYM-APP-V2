# Public VAPID key, embedded into the client bundle at build time (CRA requires the REACT_APP_ prefix).
REACT_APP_VAPID_PUBLIC_KEY=

# Private VAPID key, server-side only. Never expose this to the client.
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Upstash Redis (stores push subscriptions). Add the Upstash integration from the
# Vercel dashboard (Storage tab) to have these filled in automatically, or create
# a database at https://console.upstash.com and copy the REST URL/token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash (schedules the delayed push send). Same Upstash account, "QStash" tab.
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Optional: only needed if QStash can't infer your deployment URL from the request host.
PUBLIC_BASE_URL=
